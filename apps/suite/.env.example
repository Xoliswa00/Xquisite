APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_DOMAIN=xquisite.co.za

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,database
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
LOG_DB_LEVEL=error

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
# Default is smtp. Switch to "log" during local dev to drop mail silently.
MAIL_MAILER=smtp
# MAIL_SCHEME=smtps   # use "smtps" for port 465 (implicit SSL), "smtp" for port 587 (STARTTLS), null for plain
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Gmail (port 587 + STARTTLS) ──
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-app-password   # generate at myaccount.google.com/apppasswords
# MAIL_ENCRYPTION=tls

# ── Mailtrap (local testing) ──
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=<mailtrap-username>
# MAIL_PASSWORD=<mailtrap-password>
# MAIL_ENCRYPTION=tls

# ── Resend (transactional production) ──
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=465
# MAIL_USERNAME=resend
# MAIL_PASSWORD=re_xxxxxxxxxxxx
# MAIL_ENCRYPTION=ssl

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── Billing App Bridge ──────────────────────────────────────────────────────
# URL where the billing app is running (no trailing slash)
BILLING_URL=http://localhost:8001
# REQUIRED — shared secret between suite and billing apps. Must be the same on both sides.
# Generate with: php artisan key:generate --show (or any 32+ char random string)
# An empty value will silently break all billing sync in production.
BILLING_INTERNAL_KEY=

# PayFast (South African payment gateway)
# IMPORTANT: replace with your LIVE credentials before going to production.
# The values below are PayFast sandbox test credentials — they will NOT process real payments.
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
